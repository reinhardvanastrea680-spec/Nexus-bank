rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin UID ────────────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null && request.auth.uid == "rxj5upvJRFaUDqmH7Evfk95QuYN2";
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || request.auth.uid == userId;

      match /transactions/{txId} {
        allow read, write: if isAdmin() || request.auth.uid == userId;
      }
    }

    // ── Transactions ─────────────────────────────────────────────────────────
    match /transactions/{txId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // ── Notifications ────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.recipientId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() ||
        (isAuthenticated() && resource.data.recipientId == request.auth.uid);
    }

    // ── Beneficiaries — any authenticated user can write (admin approves) ────
    match /beneficiaries/{benId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // ── Beneficiary Requests ─────────────────────────────────────────────────
    match /beneficiaryRequests/{reqId} {
      allow read, write: if isAuthenticated();
    }

    // ── Chats ────────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read, write: if isAuthenticated();

      match /messages/{msgId} {
        allow read, write: if isAuthenticated();
      }
    }

    // ── Custom Banks ─────────────────────────────────────────────────────────
    match /customBanks/{bankId} {
      allow read, write: if isAuthenticated();
    }

    // ── Prospective Chats & Contacts ─────────────────────────────────────────
    match /prospectiveChats/{chatId} {
      allow read, write: if isAuthenticated();
      match /messages/{msgId} {
        allow read, write: if isAuthenticated();
      }
    }

    match /prospectiveContacts/{contactId} {
      allow read, write: if isAuthenticated();
    }

    // ── Admin Activity Logs ──────────────────────────────────────────────────
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    // ── Catch-all: authenticated users can read/write remaining collections ───
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
